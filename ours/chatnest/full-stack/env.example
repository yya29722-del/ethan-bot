# Auth mode:
# - app: use the in-app password only. Recommended for normal/self-hosted use.
# - both: require browser Basic Auth first, then the in-app password. Use only behind HTTPS.
AUTH_MODE=app

# Required for the in-app password login.
CHAT_PASSWORD=change-me
CHAT_SECRET=change-this-random-secret

# Only used when AUTH_MODE=both.
BASIC_AUTH_USER=
BASIC_AUTH_PASSWORD=


# Optional local Chroma/BM25 memory retrieval service.
# Create CLAUDE.md, profile.json or memories/*.md, then run ./run-memory-vectorize.sh.
# Start it with ./run-memory-search.sh or use ./run-with-memory.sh.
MEMORY_SEARCH_URL=http://127.0.0.1:3900/search
MEMORY_SEARCH_PORT=3900
MEMORY_CHROMA_DIR=memory/chroma_db
MEMORY_STATE_FILE=memory/chroma_state.json
MEMORY_VEC_POOL=8
MEMORY_BM25_POOL=12
MEMORY_AUTO_VECTORIZE=1
